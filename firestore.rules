rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check roles
    function hasRole(role) {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }
    
    function isSuperAdmin() { return hasRole('super_admin'); }
    function isAdmin() { return hasRole('admin') || isSuperAdmin(); }
    function isKitchen() { return hasRole('kitchen') || isAdmin(); }
    function isCashier() { return hasRole('cashier') || isAdmin(); }
    function isAuthenticated() { return request.auth != null; }

    // Users: Only Super Admin can manage, everyone can read their own
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isSuperAdmin());
      allow write: if isSuperAdmin();
    }
    
    // Menu: Public read for shop, only Admins can write
    match /menu/{document=**} {
      allow read: if true;  // Public access for shop
      allow write: if isAdmin();
    }
    
    // Categories: Public read for shop, only Admins can write
    match /categories/{document=**} {
      allow read: if true;  // Public access for shop
      allow write: if isAdmin();
    }
    
    // Orders: Kitchen can read/update, Cashier can create/read
    match /orders/{document=**} {
      allow read: if isKitchen() || isCashier();
      allow create: if isCashier();
      allow update: if isKitchen() || isCashier();
    }
    
    // Audit Trails: Only Super Admin
    match /audit_trails/{document=**} {
      allow read, write: if isSuperAdmin();
    }

    // ============================================
    // NEW FEATURES - SECURITY RULES
    // ============================================

    // EXPENSES: Admin only (Super Admin & Admin)
    match /expenses/{document=**} {
      allow read, write: if isAdmin();
    }

    // CUSTOMERS: Admin & Cashier can manage
    match /customers/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isCashier();
    }

    // PROMOS (Discount & Promo System): Admin only
    match /promos/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // INVENTORY ALERTS: Admin only
    match /inventory_alerts/{document=**} {
      allow read, write: if isAdmin();
    }

    // SETTINGS: Public read for shop config, Admin only for write
    match /settings/{document=**} {
      allow read: if true;  // Public access for shop display
      allow write: if isAdmin();
    }

    // SHOP CONFIG: Public read, Admin write
    match /shopConfig/{document=**} {
      allow read: if true;  // Public access for shop display
      allow write: if isAdmin();
    }

    // TABLE MANAGEMENT
    // Tables: Kitchen & Admin can update, Cashier can read
    match /tables/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isKitchen();
    }

    // Table Orders: Kitchen & Cashier can manage
    match /table_orders/{document=**} {
      allow read: if isKitchen() || isCashier();
      allow write: if isKitchen() || isCashier();
    }

    // Split Bills: Cashier only
    match /split_bills/{document=**} {
      allow read: if isCashier();
      allow write: if isCashier();
    }

    // SUPPLIER MANAGEMENT
    // Suppliers: Admin only
    match /suppliers/{document=**} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Purchase Orders: Admin only
    match /purchase_orders/{document=**} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // EMPLOYEE TIME TRACKING
    // Time Records: Everyone can read own, Admin can read all
    match /time_records/{recordId} {
      allow read: if isAuthenticated() && 
        (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated() && 
        request.auth.uid == request.resource.data.userId;
      allow update: if isAuthenticated() && 
        (request.auth.uid == resource.data.userId || isAdmin());
    }

    // Shifts: Admin only
    match /shifts/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Payroll: Admin only
    match /payroll/{document=**} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // SYNC QUEUE (Offline Mode): User can only access own items
    match /sync_queue/{itemId} {
      allow read, write: if isAuthenticated() && 
        request.auth.uid == resource.data.userId;
    }

    // OFFLINE ORDERS (Offline Mode): User can only access own items
    match /offline_orders/{orderId} {
      allow read, write: if isAuthenticated() && 
        request.auth.uid == resource.data.userId;
    }

    // BACKUPS (SimpleBackupManager): Admin only
    match /backups/{document=**} {
      allow read, write: if isAdmin();
    }

    // CHAT / MESSAGING SYSTEM
    // Conversations: Public create for customers, Admin can read all
    match /conversations/{conversationId} {
      allow read, write: if true; // Public access for shop customers (anonymous)
    }

    // Messages: Public create for customers, Admin can read all
    match /messages/{messageId} {
      allow read, write: if true; // Public access for shop customers (anonymous)
    }
  }
}
